TARGET = Zipcord.exe
CC = gcc

CFLAGS = -Wall -std=c17 -O3 -DSQLITE_THREADSAFE=0 -DSQLITE_DEFAULT_MEMSTATUS=0 -mwindows
SRC = main.c sqlite3.c
LIBS = -lgdi32 -luser32 -lshell32 -lmsimg32
all: $(TARGET)
$(TARGET): $(SRC)
	$(CC) $(CFLAGS) $(SRC) -o $(TARGET) $(LIBS)

run: $(TARGET)
	./$(TARGET)

clean:
	@if exist $(TARGET) del $(TARGET)

.PHONY: all run clean
